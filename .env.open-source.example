# Oyster open-source execution environment template
# Copy to .env.open-source.local and customize as needed.

# ------------------------------
# Desktop / forge signing config
# ------------------------------
APPLE_SIGN_IDENTITY="Developer ID Application: Oyster Dev (TEAMID1234)"
APPLE_API_KEY_PATH="/absolute/path/to/AuthKey_PLACEHOLDER_ASC.p8"
APPLE_API_KEY_ID="ASC_KEY_ID"
APPLE_API_ISSUER="ASC_ISSUER_ID"
WINDOWS_MANUFACTURER="Oyster Contributors"
CODE_SIGN_CERTIFICATE_FILE="/absolute/path/to/windows-signing-cert.pfx"
CODE_SIGN_CERTIFICATE_PASSWORD="change-me"

# ------------------------------
# iOS / fastlane config
# ------------------------------
IOS_APP_IDENTIFIER="com.example.oyster"
IOS_APP_IDENTIFIER_LIST="com.example.oyster,com.example.oyster.ShareViewController,com.example.oyster.shortcuts"
APPLE_ID_EMAIL="developer@example.com"
APPLE_TEAM_ID="TEAMID1234"
MATCH_GIT_URL="git@github.com:example/fastlane-certificates.git"
APP_STORE_CONNECT_API_KEY_KEY_ID="ASC_KEY_ID"
APP_STORE_CONNECT_API_KEY_ISSUER_ID="ASC_ISSUER_ID"
APP_STORE_CONNECT_API_KEY_FILEPATH="../AuthKey_PLACEHOLDER.p8"

# ------------------------------
# Multi-upstream sync (future Huncho wiring)
# ------------------------------
HUNCHO_REMOTE_URL="git@github.com:example/huncho.git"
HUNCHO_DEFAULT_BRANCH="main"

# ------------------------------
# DB sync helper scripts
# ------------------------------
DB_SYNC_BASE_URL="http://127.0.0.1:8787"
DB_SYNC_ADMIN_TOKEN="replace-with-db-sync-admin-token"
BASE_URL="http://127.0.0.1:8787"
GRAPH_ID="dev-graph"

# ------------------------------
# Cloudflare Worker deploy (used by scripts/deploy-worker.sh)
# ------------------------------
COGNITO_ISSUER="https://cognito-idp.us-east-1.amazonaws.com/us-east-1_YOURPOOLID"
COGNITO_CLIENT_ID="your-cognito-client-id"

# db-sync worker
DB_SYNC_R2_BUCKET="your-sync-assets-bucket"
DB_SYNC_D1_NAME="your-sync-db-name"
DB_SYNC_D1_ID="your-d1-database-id"
DB_SYNC_SENTRY_DSN="https://your-sentry-dsn"
DB_SYNC_STAGING_R2_BUCKET="your-staging-sync-assets-bucket"
DB_SYNC_STAGING_D1_NAME="your-staging-sync-db-name"
DB_SYNC_STAGING_D1_ID="your-staging-d1-id"
DB_SYNC_PROD_R2_BUCKET="your-prod-sync-assets-bucket"
DB_SYNC_PROD_D1_NAME="your-prod-sync-db-name"
DB_SYNC_PROD_D1_ID="your-prod-d1-id"

# publish worker
PUBLISH_R2_BUCKET="your-publish-dev-bucket"
PUBLISH_STAGING_R2_BUCKET="your-publish-staging-bucket"
PUBLISH_PROD_R2_BUCKET="your-publish-prod-bucket"
PUBLISH_CUSTOM_DOMAIN="your-publish-domain.com"
